generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(THERAPIST)
  maxPatients Int    @default(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patients    Patient[]
  treatments  Treatment[]
  appointments Appointment[]
  consents    UserConsent[]
  enterpriseRequest EnterpriseRequest?
  review      Review?
  subscription Subscription?

  @@map("users")
}

model Patient {
  id            String   @id @default(cuid())
  name          String
  cpf           String   @unique
  birthDate     DateTime
  phone         String
  email         String?
  address       String?
  medicalHistory String?
  status        PatientStatus @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id])

  treatments   Treatment[]
  appointments Appointment[]

  @@map("patients")
}

model Treatment {
  id            String   @id @default(cuid())
  estimatedTime String
  exercises     String
  value         Decimal
  status        TreatmentStatus @default(IN_PROGRESS)
  startDate     DateTime @default(now())
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  userId String
  user   User @relation(fields: [userId], references: [id])

  sessions   Session[]
  payments   Payment[]

  @@map("treatments")
}

model Session {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  weight      Decimal?
  painScale   Int
  measurements Json?
  notes       String?
  createdAt   DateTime @default(now())

  treatmentId String
  treatment   Treatment @relation(fields: [treatmentId], references: [id])

  @@map("sessions")
}

model Appointment {
  id              String   @id @default(cuid())
  scheduledAt     DateTime
  status          AppointmentStatus @default(PENDING)
  reminderSent    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  userId String
  user   User @relation(fields: [userId], references: [id])

  @@map("appointments")
}

model Payment {
  id            String   @id @default(cuid())
  value         Decimal
  dueDate       DateTime
  paidDate      DateTime?
  status        PaymentStatus @default(PENDING)
  receipt       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  treatmentId String
  treatment   Treatment @relation(fields: [treatmentId], references: [id])

  @@map("payments")
}

enum Role {
  ADMIN
  THERAPIST
}

enum PatientStatus {
  ACTIVE
  INACTIVE
}

enum TreatmentStatus {
  IN_PROGRESS
  PAUSED
  COMPLETED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum DocumentType {
  PRIVACY_POLICY
  TERMS_OF_USE
  CONSENT_TERMS
}

model UserConsent {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  documentType    DocumentType
  documentVersion String
  consentedAt     DateTime @default(now())
  revokedAt       DateTime?
  ipAddress       String?

  @@unique([userId, documentType])
  @@map("user_consents")
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model EnterpriseRequest {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  companyName     String
  cnpj            String?
  teamSize        Int
  phone           String
  message         String?
  status          RequestStatus @default(PENDING)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("enterprise_requests")
}

model Review {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  rating      Int
  comment     String?
  dismissedAt DateTime?
  createdAt   DateTime @default(now())

  @@map("reviews")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id])
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 PlanType           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  priceChangedAt       DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@map("subscriptions")
}

model WebhookEvent {
  id             String   @id @default(cuid())
  stripeEventId  String   @unique
  type           String
  processed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@map("webhook_events")
}
